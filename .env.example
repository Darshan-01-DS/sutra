# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# Production URL (e.g. https://sutra.vercel.app)
NEXTAUTH_URL=https://your-vercel-domain.vercel.app

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/sutra?retryWrites=true&w=majority

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: https://your-vercel-domain.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── GitHub OAuth (optional) ──────────────────────────────────────────────────
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── AI (optional) ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── ImageKit (optional, for file uploads) ────────────────────────────────────
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id
